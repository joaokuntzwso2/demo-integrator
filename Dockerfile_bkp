ARG MI_IMAGE=wso2/wso2mi:4.5.0
FROM ${MI_IMAGE}

USER root

# Tools needed for TLS bootstrap
RUN microdnf install -y openssl && microdnf clean all || true

# Copy MI config + artifacts (CAR)
COPY demo-mi/deployment/deployment.toml /home/wso2carbon/wso2mi-4.5.0/conf/deployment.toml
COPY demo-mi/target/demo-mi_1.0.0.car /home/wso2carbon/wso2mi-4.5.0/repository/deployment/server/carbonapps/

# Trust bootstrap script
COPY demo-mi/deployment/docker/resources/init-icp-trust.sh /home/wso2carbon/init-icp-trust.sh
RUN chmod +x /home/wso2carbon/init-icp-trust.sh \
  && chown -R wso2carbon:wso2 /home/wso2carbon/init-icp-trust.sh

USER wso2carbon

# Run trust bootstrap then normal entrypoint
ENTRYPOINT ["/bin/bash", "-lc", "/home/wso2carbon/init-icp-trust.sh && /home/wso2carbon/docker-entrypoint.sh"]